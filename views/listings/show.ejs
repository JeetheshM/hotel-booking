<% layout("/layout/boilerplate") %>
    <div class="row mt-3">
    <div class="col-12 col-md-10 col-lg-8 mx-auto mt-3">
          <h2><%= listing.title %></h2>
        </div>
  <div class="card col-12 col-md-10 col-lg-8 mx-auto show-card listing-card">
                 
      <img 
  src="<%= listing.image.url || 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee' %>"
  class="img-fluid rounded"
  style="max-height: 400px; object-fit: cover;"
  alt="listing_image"
>




        <div class="card-body">
          <p class="card-text mt-3">
            <i>Owned By: <%= listing.owner ? listing.owner.username : "Unknown" %></i>
            <br>
          Description: <%= listing.description %><br>
          Price:
                        <% if (listing.price != null) { %>
                          &#8377;<%= listing.price.toLocaleString("en-IN") %> /night
                        <% } else { %>
                          Not specified
                        <% } %>
                        <br>
            Location: <%= listing.location %><bR>
            Country: <%= listing.country %>

        </div>
    </div>
    <!-- <ul> -->
        <!-- <li>Title: <%= listing.title %></li> -->
        <!-- <img src="<%= listing.image %>" alt="Listing Image" style="max-width:300px;"> -->
        <!-- <li> -->
  <!-- Price: -->
  <!-- <% if (listing.price != null) { %>
    &#8377;<%= listing.price.toLocaleString("en-IN") %> per night
  <% } else { %>
    Not specified
  <% } %> -->
<!-- </li>
        <li></li>
        <li></li>
        <li></li>
    </ul> -->
  <%if(currUser && listing.owner._id.equals(currUser._id)) {%>
  <div class="btns col-12 col-md-10 col-lg-8 mx-auto mt-2 mb-2">
     <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark add-btn">Edit </a>
       
      <form method="post" action="/listings/<%= listing._id%>?_method=DELETE" >
      <button class="btn btn-dark">Delete </button>
    </form>
  </div>
  <%}%>

  <div class="col-12 col-md-10 col-lg-8 mx-auto mb-3">
    

    <%if(currUser) {%>
      <hr>
    <h4>Leave a Review</h4>
    <form action="/listings/<%=listing._id %>/reviews" method="POST" novalidate class="needs-validation">
      <div class="mb-3 mt-3">
        <label class="form-label">Rating</label>
      <fieldset class="starability-slot">
  <legend>Rating:</legend>
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
      </div>
      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comment</label>
        
          
        <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
        <div class="invalid-feedback">please add the review for god sake</div>
      </div>
      <button class="btn btn-outline-dark mb-3">Submit</button>
    </form>
      <%}%>

   
    <%if(listing.reviews.length > 0){ %>
      <hr>
      <h4><b>All Reviews</b></h4>
    <div class="row row-cols-1 row-cols-md-2 g-4 mt-3">
       
      <% for(review of listing.reviews){ %>
        <div class="col">
          <div class="card h-100">
            <div class="card-body">
              <p class="card-text"><b> @<%=review.author.username%></b></p>
              <p class="starability-result card-title" data-rating="<%= review.rating %>">
                Rated: <%= review.rating %> stars
              </p>
              <p class="card-text"><%=review.comment%></p>
              <!-- <p class="card-text"><small class="text-muted">Posted on <%=review.createdAt ? new Date(review.createdAt).toLocaleDateString() : 'Recently'%></small></p> -->
            </div>
            <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
              <form class="mb-3 ms-1 mt-2" method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
              </form>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
    
  </div>
  <%}%>

</div>
